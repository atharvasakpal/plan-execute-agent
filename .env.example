# API Configuration
GOOGLE_API_KEY=your_google_api_key_here
ENVIRONMENT=development

# CORS (comma-separated origins)
ALLOWED_ORIGINS=*

# Model Configuration
MODEL_NAME=gemini-2.5-flash
MODEL_TEMPERATURE=1.0
MAX_RETRIES=3
TIMEOUT_SECONDS=300

# AWS Configuration (for deployment)
AWS_REGION=us-east-1
